GEMINI_API_KEY=your-gemini-api-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
CALLBACK_URL=http://localhost:8000/auth/callback
DATABASE_PATH=./gmail_gchat_bot.db
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CHAT_SERVICE_ACCOUNT_FILE=./chat-service-account.json
# Audio summary storage backend: local for dev, firebase for production
STORAGE_BACKEND=local
# Firebase Storage bucket hostname; defaults to this project bucket if unset
FIREBASE_STORAGE_BUCKET=landinc-signal-folio.firebasestorage.app
# Required only when STORAGE_BACKEND=firebase; points to a service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=
